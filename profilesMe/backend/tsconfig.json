{
  "compilerOptions": {
    "module": "commonjs",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "target": "es6",
    "moduleResolution": "node",
    "sourceMap": true,
    "outDir": "build",
    "rootDir": "./",
    "lib": ["es2015"]
  },
  "include": ["src/**/*", "api/**/*"],
  "exclude": ["node_modules", "build"]
}
